{
  "expo": {
    "name": "Frapp",
    "slug": "Frapp",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/FRAPP_ICON1.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/FRAPP_ICON1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brianali.Frapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/FRAPP_ICON1.png",
        "monochromeImage": "./assets/images/FRAPP_ICON2.png",
        "backgroundColor": "#9333ea"
      },
      "package": "com.brianali.Frapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/FRAPP_ICON1.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "../../node_modules/@notifee/react-native/android/libs"
            ]
          }
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "5101bc22-4bca-4375-bec7-4e1a4c143d06"
      },
      "castarSdkClientId": "cskfmx+CSswYnR"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
